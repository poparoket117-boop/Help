-- DrunixHub (K to toggle mouse look)
local player = game.Players.LocalPlayer
local camera = workspace.CurrentCamera
local uis = game:GetService("UserInputService")

local enabled = false
local sensitivity = 0.005

uis.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.K then
        enabled = not enabled
        if enabled then
            camera.CameraType = Enum.CameraType.Scriptable
            print("Mouse look ON")
        else
            camera.CameraType = Enum.CameraType.Custom
            print("Mouse look OFF")
        end
    end
end)

game:GetService("RunService").RenderStepped:Connect(function()
    if enabled then
        local delta = uis:GetMouseDelta()
        if delta.X ~= 0 or delta.Y ~= 0 then
            local rotationX = CFrame.Angles(0, -delta.X * sensitivity, 0)
            local rotationY = CFrame.Angles(-delta.Y * sensitivity, 0, 0)
            camera.CFrame = camera.CFrame * rotationX * rotationY
        end
    end
end)

print("Press K to toggle mouse look.")
